{
  "manifest_version": 2,
  "name": "Clean Browsing",
  "version": "1.2.0",
  "description": "A customizable, local-first new tab page for Firefox — a grid of draggable, resizable widgets.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "geolocation",
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "clean-browsing-next@local",
      "strict_min_version": "109.0"
    }
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "48": "icons/logo.png",
    "96": "icons/logo.png"
  }
}
