{
  "manifest_version": 2,
  "name": "Clean Browsing (next)",
  "version": "0.0.5",
  "description": "A customizable new tab page — rebuilt with Svelte 5, Tailwind v4, and shadcn-svelte.",
  "permissions": ["storage", "unlimitedStorage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "clean-browsing-next@local",
      "strict_min_version": "109.0"
    }
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "48": "icons/logo.png",
    "96": "icons/logo.png"
  }
}
