    "concurrently": "^9.1.2",
    "svelte": "^5.28.1",
    "svelte-check": "^4.1.5",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "web-ext": "^8.4.0"
  },
  "dependencies": {
    "bits-ui": "^1.3.17",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "fflate": "^0.8.2",
    "lucide-svelte": "^0.475.0",
    "mode-watcher": "^0.5.0",
    "svelte-sonner": "^0.3.28",
