{
  "name": "clean-browsing",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite build --watch\" \"web-ext run --source-dir=dist --target=firefox-desktop --no-reload-extension --firefox-profile=.firefox-dev-profile --profile-create-if-missing --keep-profile-changes\"",
    "build": "vite build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,js,svelte,css,html}\" \"*.{ts,js,json,md}\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,svelte,css,html}\" \"*.{ts,js,json,md}\" \"docs/**/*.md\"",
    "package": "web-ext build --source-dir=dist --artifacts-dir=web-ext-artifacts --overwrite-dest",
    "sign": "web-ext sign --source-dir=dist --artifacts-dir=web-ext-artifacts --api-key=$WEB_EXT_API_KEY --api-secret=$WEB_EXT_API_SECRET --channel=unlisted",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^22.14.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.28.1",
    "svelte-check": "^4.1.5",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.3.2",
    "web-ext": "^8.4.0"
  },
  "dependencies": {
    "bits-ui": "^1.3.17",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "dompurify": "^3.4.0",
    "fflate": "^0.8.2",
    "lucide-svelte": "^0.475.0",
    "marked": "^18.0.0",
    "mode-watcher": "^0.5.0",
    "svelte-sonner": "^0.3.28",
    "tailwind-merge": "^3.2.0",
    "tailwind-variants": "^0.3.1"
  }
}
